{
  "description": "cc-yes: auto-approve based on yes rules",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [{
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hook-entry.sh pretooluse",
          "timeout": 86400
        }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/scripts/hook-entry.sh posttooluse"
        }]
      }
    ]
  }
}
